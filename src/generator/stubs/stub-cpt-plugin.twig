declare(strict_types=1);

namespace {{ namespace }};

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

if ( class_exists( '\Queulat\Helpers\Autoloader' ) ) {
	\Queulat\Helpers\Autoloader::boot( '{{ namespace }}', __DIR__ . '/includes' );
}

add_action(
	'plugins_loaded',
	function() {
		$post_type = new Post_Type();
		$post_type->init();
	}
);

register_activation_hook(
	__FILE__,
	function () {
		if ( ! class_exists( '{{ namespace }}\Post_Type' ) ) {
			require_once trailingslashit( plugin_dir_path( __FILE__ ) ) . 'includes/class-post-type.php';
		}
		Post_Type::activate_plugin();
	}
);

add_action( 'init', array( '\{{ namespace }}\Post_Type', 'register_post_type' ) );
