if ( class_exists( '\Queulat\Helpers\Autoloader' ) ) {
	\Queulat\Helpers\Autoloader::boot( '', __DIR__ . '/includes' );
}

add_filter(
	'queulat_service_providers',
	static function ( array $providers ): array {
		$providers[] = new {{ class_name }}_Service_Provider();
		return $providers;
	}
);

( new {{ class_name }}_Post_Type() )->init();

register_activation_hook(
\t__FILE__,
\tfunction () {
\t\tif ( ! class_exists( '{{ class_name }}_Post_Type' ) ) {
\t\t\trequire_once trailingslashit( plugin_dir_path( __FILE__ ) ) . 'includes/class-{{ file_name }}-post-type.php';
\t\t}
\t\t{{ class_name }}_Post_Type::activate_plugin();
\t}
);

add_action(
	'plugins_loaded',
	function () {
		if ( ! class_exists( '{{ class_name }}_Post_Type' ) ) {
			require_once trailingslashit( plugin_dir_path( __FILE__ ) ) . 'includes/class-{{ file_name }}-post-type.php';
		}
		if ( ! class_exists( '{{ class_name }}_Post_Query' ) ) {
			require_once trailingslashit( plugin_dir_path( __FILE__ ) ) . 'includes/class-{{ file_name }}-post-query.php';
		}
		if ( ! class_exists( '{{ class_name }}_Post_Object' ) ) {
			require_once trailingslashit( plugin_dir_path( __FILE__ ) ) . 'includes/class-{{ file_name }}-post-object.php';
		}
	}
);

add_action( 'init', array( '{{ class_name }}_Post_Type', 'register_post_type' ) );
